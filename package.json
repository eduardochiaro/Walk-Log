        },
        {
          "type": "bitmap",
          "name": "ICON_SETTINGS",
          "file": "icon_settings.png"
        },
        {
          "type": "bitmap",
          "name": "ICON_PLAY",
          "file": "icon_play.png"
        },
        {
          "type": "bitmap",
          "name": "ICON_STOP",
          "file": "icon_stop.png"
        },
        {
          "type": "bitmap",
          "name": "ICON_LOGS",
          "file": "icon_logs.png"
        }
      ]
    }
