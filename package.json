        {
          "type": "bitmap",
          "name": "ICON_SETTINGS_WHITE",
          "file": "icon_settings_white.png"
        },
        {
          "type": "bitmap",
          "name": "ICON_PLAY_WHITE",
          "file": "icon_play_white.png"
        },
        {
          "type": "bitmap",
          "name": "ICON_STOP_WHITE",
          "file": "icon_stop_white.png"
        },
        {
          "type": "bitmap",
          "name": "ICON_LOGS_WHITE",
          "file": "icon_logs_white.png"
        }
      ]
    }
