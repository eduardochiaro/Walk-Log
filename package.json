{
  "name": "walk-log",
  "author": "Eduardo Chiaro",
  "version": "1.0.0",
  "keywords": [
    "pebble-app",
    "health",
    "steps",
    "logs",
    "walking",
    "walk",
    "dog"
  ],
  "private": true,
  "dependencies": {
    "pebble-timeline-js": "^2.2.0"
  },
  "pebble": {
    "displayName": "Walk Log",
    "uuid": "c013951f-72e4-453a-be4f-1fbee9014b0f",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite",
      "emery",
      "flint"
